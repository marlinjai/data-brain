# Data Brain — Environment Variables (Node.js / self-hosted mode)

# PostgreSQL connection string (required)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/databrain

# Admin API key for tenant management (required)
ADMIN_API_KEY=admin-dev-key

# Server port (default: 3001)
PORT=3001

# Environment label (development | staging | production)
ENVIRONMENT=development
